      "text": "Representa un elemento u objeto del\nmundo real con identidad, se diferencia\nde cualquier otro elemento.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Representa un elemento u objeto del mundo real con identidad, se diferencia de cualquier otro elemento.",
